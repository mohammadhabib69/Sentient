# Sentient local development environment
# Copy this file to .env before starting services.
#
# Production security notes:
# - Never reuse these local defaults in staging or production.
# - Store production secrets in a secret manager, not in git or plain env files.
# - Use strong, unique values for database, Neo4j, MinIO/S3, JWT, and API keys.
# - Rotate secrets immediately if a real value is committed or shared.
# - Bind local Docker ports to localhost or private networks in shared environments.

###############################################################################
# Required: PostgreSQL / TimescaleDB
###############################################################################

# Docker Compose user created inside the local PostgreSQL container.
POSTGRES_USER=sentient

# Docker Compose password for the local PostgreSQL user.
# Production: use a high-entropy secret.
POSTGRES_PASSWORD=sentient

# Docker Compose database name created at container startup.
POSTGRES_DB=sentient

# Host port exposed for local PostgreSQL access.
POSTGRES_PORT=5432

# Prisma PostgreSQL connection string.
# Required by Prisma migrations, Prisma Client, and API/database packages.
DATABASE_URL=postgresql://sentient:sentient@localhost:5432/sentient

###############################################################################
# Required: Redis
###############################################################################

# Host port exposed for local Redis access.
REDIS_PORT=6379

# ioredis/BullMQ connection string.
REDIS_URL=redis://localhost:6379

###############################################################################
# Required: Neo4j
###############################################################################

# Neo4j username. The official image requires the default user to be neo4j.
NEO4J_USER=neo4j

# Neo4j password for local development.
# Production: use a high-entropy secret and do not expose browser/bolt publicly.
NEO4J_PASSWORD=sentient-neo4j-password

# Host port exposed for Neo4j Browser.
NEO4J_HTTP_PORT=7474

# Host port exposed for Neo4j Bolt.
NEO4J_BOLT_PORT=7687

# Neo4j Bolt connection string used by the graph package.
NEO4J_URI=bolt://localhost:7687

###############################################################################
# Required: Authentication
###############################################################################

# JWT signing secret. Must be at least 32 characters.
# Production: generate a random secret, store it in a secret manager, and rotate
# with a planned token invalidation window.
JWT_SECRET=replace-with-at-least-32-random-characters

# Access token lifetime.
JWT_EXPIRES_IN=15m

# Refresh token lifetime.
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth 2.0 credentials (optional for development)
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

###############################################################################
# Required: Web / CORS
###############################################################################

# Allowed frontend origin for CORS and app-generated links.
FRONTEND_URL=http://localhost:3000

# Frontend dashboard URL for OAuth redirects after successful authentication
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard

# Frontend login URL for OAuth redirects after failed authentication
FRONTEND_LOGIN_URL=http://localhost:3000/login

###############################################################################
# Required for AI features
###############################################################################

# OpenAI API key for agent orchestration and embedding workflows.
# Local setup can leave this placeholder until AI calls are implemented.
OPENAI_API_KEY=replace-with-openai-api-key

###############################################################################
# Required for billing features
###############################################################################

# Stripe secret key for subscription and billing APIs.
# Use test keys locally; use live keys only in production secret storage.
STRIPE_SECRET_KEY=replace-with-stripe-secret-key

###############################################################################
# Required for email features
###############################################################################

# Resend API key for transactional emails.
RESEND_API_KEY=replace-with-resend-api-key

# Email sender address (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com

###############################################################################
# Required: S3-compatible file storage
###############################################################################

# MinIO root user for local object storage.
MINIO_ROOT_USER=sentient

# MinIO root password for local object storage.
# Production: use AWS/Supabase/object-storage credentials from a secret manager.
MINIO_ROOT_PASSWORD=sentient-minio-password

# Host port exposed for the MinIO S3-compatible API.
MINIO_API_PORT=9000

# Host port exposed for the MinIO web console.
MINIO_CONSOLE_PORT=9001

# Bucket name used by file storage code.
S3_BUCKET=sentient-dev

# S3-compatible endpoint. Local development uses MinIO.
S3_ENDPOINT=http://localhost:9000

###############################################################################
# Optional: local developer overrides
###############################################################################

# Set to 1 if a local script should overwrite an existing .env from this example.
OVERWRITE_ENV=0
