{
  "name": "@sentient/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist coverage generated",
    "db:generate": "node -e \"console.log('Prisma schema will be added in the Phase 0 database step.')\"",
    "db:migrate": "node -e \"console.log('Database migrations will be added in the Phase 0 database step.')\"",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "7.8.0"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "tsx": "4.22.3"
  }
}
