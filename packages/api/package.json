{
  "name": "@sentient/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@sentient/agents": "workspace:*",
    "@sentient/billing": "workspace:*",
    "@sentient/database": "workspace:*",
    "@sentient/events": "workspace:*",
    "@sentient/graph": "workspace:*",
    "@sentient/queue": "workspace:*",
    "@sentient/realtime": "workspace:*",
    "@sentient/shared": "workspace:*",
    "@sentient/webhooks": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "5.77.2",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "8.2.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "1.10.1",
    "neo4j-driver": "6.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.4",
    "socket.io": "4.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "1.9.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "7.8.0",
    "tsx": "4.22.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
