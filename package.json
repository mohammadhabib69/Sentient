{
  "name": "sentient",
  "version": "0.0.0",
  "private": true,
  "description": "Sentient is an AI-Native Business Reality Engine built as a modular monolith with event sourcing, CQRS, graph intelligence, and human-in-the-loop agent approvals.",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.3.0"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rimraf node_modules .turbo",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "turbo db:generate --filter=@sentient/database",
    "db:migrate": "turbo db:migrate --filter=@sentient/database",
    "db:seed": "turbo db:seed --filter=@sentient/database"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  }
}
