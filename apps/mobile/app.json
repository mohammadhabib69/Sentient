{
  "expo": {
    "name": "Sentient",
    "slug": "sentient",
    "scheme": "sentient",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": ["expo-router"],
    "experiments": {
