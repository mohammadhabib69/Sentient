{
  "name": "@sentient/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "lint": "eslint app --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .expo coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.12",
    "@sentient/shared": "workspace:*",
    "expo": "56.0.4",
    "expo-router": "56.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/react": "19.2.15"
  }
}
